rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isSignedIn() {
      return request.auth != null;
    }

    function isHqOperator() {
      return isSignedIn()
        && request.auth.token.email != null
        && request.auth.token.email == 'pratyanshrana1@gmail.com';
    }

    function isChatMember(chatId) {
      return isSignedIn()
        && request.auth.uid in get(/databases/$(database)/documents/chats/$(chatId)).data.memberUids;
    }

    match /hq_operators/{docId} {
      allow read: if isSignedIn() && docId == 'hq_operator';
      allow write: if false;
    }

    match /activity_events/{eventId} {
      allow create: if isSignedIn();
      allow read: if isHqOperator();
      allow update, delete: if false;
    }

    match /distress_alerts/{alertId} {
      allow create: if isSignedIn() && request.resource.data.uid == request.auth.uid;
      allow read, update: if isHqOperator();
      allow delete: if false;
    }

    match /personnel/{document} {
      allow read, write: if true;
    }

    match /dependents/{document} {
      allow read, write: if true;
    }

    match /connection_requests/{document} {
      allow read, create, update: if isSignedIn();
    }

    match /group_invitations/{document} {
      allow read, create, update: if isSignedIn();
    }

    match /chats/{chatId} {
      allow read, create, update: if isSignedIn();
      allow delete: if isChatMember(chatId) || isHqOperator();

      match /messages/{messageId} {
        allow read: if isSignedIn();
        allow create: if isSignedIn() && !isHqOperator();
        allow delete: if isChatMember(chatId) || isHqOperator();
      }
    }
  }
}
